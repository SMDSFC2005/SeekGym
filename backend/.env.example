# Clave secreta de Django. Cambia esto por una cadena larga y aleatoria en producción.
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria

# Modo de depuración. Ponlo en False en producción.
DEBUG=True

# Hosts permitidos separados por coma (sin espacios).
ALLOWED_HOSTS=localhost,127.0.0.1
